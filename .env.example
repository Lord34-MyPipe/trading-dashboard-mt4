# ============================================================
# CONFIGURATION - Copie ce fichier en .env.local
# ============================================================

# Option A : URL de ton serveur Node.js sur le VPS
VPS_API_URL=http://TON-IP-VPS:3001

# Option B : MetaApi.cloud
# METAAPI_TOKEN=ton-token-metaapi
# METAAPI_ACCOUNT_IDS=id1,id2,id3,id4,id5

# Mot de passe pour protéger l'accès au dashboard (optionnel)
DASHBOARD_PASSWORD=ton-mot-de-passe-secret
